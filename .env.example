# ============================================
# Dragon Empire — Environment Variables
# Copy to .env and fill in your values
# ============================================

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Supabase (from supabase.com → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your_service_role_key...

# Your deployed URLs
WEBAPP_URL=https://dragon-empire.vercel.app
BACKEND_URL=https://dragon-empire-api.railway.app

# Shared secret (frontend → backend)
API_SECRET=change-this-to-random-string
